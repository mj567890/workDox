# ============================================================
# ODMS Backend Environment Configuration
# Copy this file to .env and fill in production values.
# ============================================================

# Application
APP_NAME="ODMS - Online Document Management System"
APP_VERSION="1.0.0"
DEBUG=false

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://odms:CHANGE_ME@localhost:5432/odms
DATABASE_URL_SYNC=postgresql://odms:CHANGE_ME@localhost:5432/odms

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=odms-documents
MINIO_SECURE=false

# JWT
# Generate a strong random key: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# File upload limits
UPLOAD_CHUNK_SIZE=5242880
MAX_FILE_SIZE=524288000

# CORS: allowed origins for the frontend
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Celery (background tasks)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LibreOffice (for document-to-HTML preview conversion)
LIBREOFFICE_PATH=/usr/bin/soffice
PREVIEW_CACHE_DAYS=30
EDIT_LOCK_TIMEOUT_HOURS=24

# ── Optional Integrations ──────────────────────────────────

# SMTP Email
SMTP_HOST=smtp.126.com
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDR=
SMTP_FROM_NAME="ODMS 文档管理系统"
SMTP_USE_TLS=true

# LDAP
LDAP_ENABLED=false
LDAP_SERVER=ldap://ad.company.com
LDAP_BASE_DN=dc=company,dc=com
LDAP_USER_DN_TEMPLATE=cn={username},ou=users,dc=company,dc=com
LDAP_ATTR_REAL_NAME=displayName
LDAP_ATTR_EMAIL=mail
LDAP_ATTR_PHONE=telephoneNumber

# CAS (Central Authentication Service)
CAS_ENABLED=false
CAS_SERVER_URL=
CAS_LOGIN_URL=/cas/login
CAS_VALIDATE_URL=/cas/serviceValidate
CAS_PROVIDER_NAME=统一认证
CAS_REDIRECT_URI=
CAS_USER_ID_ATTR=user
CAS_NAME_ATTR=cn
CAS_EMAIL_ATTR=mail

# OAuth2 / OIDC
OAUTH2_ENABLED=false
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_ISSUER=
OAUTH2_AUTHORIZE_URL=
OAUTH2_TOKEN_URL=
OAUTH2_USERINFO_URL=
OAUTH2_SCOPES=openid profile email
OAUTH2_PROVIDER_NAME=OIDC
OAUTH2_REDIRECT_URI=
OAUTH2_USER_ID_CLAIM=sub
OAUTH2_USERNAME_CLAIM=preferred_username
OAUTH2_NAME_CLAIM=name
OAUTH2_EMAIL_CLAIM=email

# AI / RAG
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=4096
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIM=768
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
